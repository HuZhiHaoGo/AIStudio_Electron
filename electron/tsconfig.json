{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "inlineSources": true,
    "outDir": "../dist-electron",
    "rootDir": "..",
    "types": ["node", "electron"]
  },
  "include": ["**/*.ts", "../shared/**/*.ts"]
}
